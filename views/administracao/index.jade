doctype html
html(lang="pt-br")
  head
    title Catch-catch
    meta(charset="UTF-8")
    meta(http-equiv="X-UA-Compatible",content="IE=edge")
    meta(name="viewport",content="width=device-width, initial-scale=1.0")
    link(rel='stylesheet', href='../stylesheets/adminindex.css')
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css",rel="stylesheet",integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC",crossorigin="anonymous")
    link(rel="shortcut icon", type="image/x-icon", href="../../images/fav-bloco.svg")
  body(class="bg-warning" style="padding: 0px;")
    section(class="container")
      div(class="m-4")
        nav(class="container text-end mb-3") 
          a(href="/admin/palavras/nova")
            button(class="btn btn-primary") + Nova palavra
        div(class="card bg-white p-4", style="background-color: rgba(0,0,0,.2);")
          table(class="table")
            thead
              tr
                th(scope="col") #
                th(scope="col") Dica
                th(scope="col") Sílabas
                th(scope="col") 

            tbody
              tr(class="tr-hover")
                th(scope="row") 1
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-bala.png", style="max-width: 50px;")
                td(class="align-middle") BA - LA
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              
              tr(class="tr-hover")
                th(scope="row") 2
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-bolo.png", style="max-width: 50px;")
                td(class="align-middle") BO - LO
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              
              tr(class="tr-hover")
                th(scope="row") 3
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-boneca.png", style="max-width: 50px;")
                td(class="align-middle") BO - NE - CA
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover")
                th(scope="row") 4
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-capacete.png", style="max-width: 50px;")
                td(class="align-middle") CA - PA - CE - TE
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover")
                th(scope="row") 5
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-janela.png", style="max-width: 50px;")
                td(class="align-middle") JA - NE - LA
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover")
                th(scope="row") 6
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-mala.png", style="max-width: 50px;")
                td(class="align-middle") MA - LA
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover")
                th(scope="row") 7
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-sapato.png", style="max-width: 50px;")
                td(class="align-middle") SA - PA - TO
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover")
                th(scope="row") 8
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-telefone.png", style="max-width: 50px;")
                td(class="align-middle") TE - LE - FO - NE
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar
              tr(class="tr-hover d-none", id="click-j")
                th(scope="row") 9
                td(class="align-middle")
                  img(src="../images/dicas/img-dica-pipoca.png", style="max-width: 50px;")
                td(class="align-middle") PI - PO - CA
                td(class="align-middle")
                  div(class="row div-action", style="visibility: hidden;")
                    button(type="button", class="col me-1 btn btn-warning btn-sm") editar
                    button(type="button", class="col btn btn-danger btn-sm") deletar       
    
    script(src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js",integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p",crossorigin="anonymous")
    script(src="../javascripts/adminindex.js")